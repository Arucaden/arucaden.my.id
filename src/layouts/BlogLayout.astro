---
import type { CollectionEntry } from 'astro:content';
import '../styles/global.css';
import ArticleContainer from '@components/ArticleContainer.astro';
import BackButton from '@components/BackButton.astro';

interface Props {
  entry: CollectionEntry<'blog'>;
  extraData?: Record<string, any>;
}

const { entry, extraData = {} } = Astro.props;
const { title, description } = { ...extraData, ...entry.data };
const { Content } = await entry.render();
---
<html>
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>

  <article class="crt-bg-flat min-h-screen mx-auto">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 md:px-8 py-8 md:py-12">
      <BackButton href="/#projects" text="Back to Projects"/>

      <ArticleContainer title={title} description={description}>
        <div class="text-sm text-white-text sm:text-base mt-6 break-words overflow-hidden">
          <div class="w-full purosu max-w-none">
            <Content />
          </div>
        </div>
      </ArticleContainer>

      <div class="mt-16 flex justify-center">
        <button 
          onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
          class="group flex items-center gap-2 text-main hover:text-white transition-colors"
          aria-label="Scroll back to top"
        >
          <span class="text-sm font-bold tracking-wider uppercase">Back to Top</span>
          <img src="/icons/arrow-down.svg" alt="Up Arrow" class="w-5 h-5 rotate-180 transition-transform duration-300 transform group-hover:-translate-y-1" />
        </button>
      </div>
    </div>
  </article>
</html>
