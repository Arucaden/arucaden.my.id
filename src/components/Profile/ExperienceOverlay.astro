---
import { experiences } from '@data/experiences.ts';
import Overlay from '@components/Overlay.astro';
import ExperienceBadge from './ExperienceBadge.svelte';
---

<Overlay id="experiences-overlay" title=".Experiences" closeButtonId="hide-all-experiences">
  <div class="space-y-2">
    {experiences.map(exp => (
      <article class="border-2 border-secondary/30 bg-black/70 rounded-lg p-2">
        <div class="flex items-center gap-1.5 min-w-0">
          <p class="prose-text font-semibold leading-tight mr-1">{exp.company}</p>
          <ExperienceBadge text={exp.type} customClass="shrink-0" />
          <ExperienceBadge text={exp.location} customClass="shrink-0" />
          <span class="ml-auto text-xs color-gray-text whitespace-nowrap">{exp.period}</span>
        </div>
        {exp.role && (
          <p class="text-xs color-gray-text mt-0.5">{exp.role}</p>
        )}
        {exp.points?.length > 0 && (
          <ul class="mt-2 list-disc list-inside space-y-1">
            {exp.points.map(pt => (
              <li class="text-sm text-white/90 leading-snug">{pt}</li>
            ))}
          </ul>
        )}
      </article>
    ))}
  </div>
</Overlay>
